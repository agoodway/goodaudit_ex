+
+  defp unwrap_tx_result({:ok, log}), do: {:ok, log}
+  defp unwrap_tx_result({:error, reason}), do: {:error, reason}
+end
diff --git a/app/test/app/audit/context_test.exs b/app/test/app/audit/context_test.exs
