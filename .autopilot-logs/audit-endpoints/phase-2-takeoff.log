+      user_agent: "ExUnit",
+      outcome: "success",
+      failure_reason: nil,
+      phi_accessed: false,
+      metadata: %{"source" => "audit_log_controller_test"}
+    }
+
+    Map.merge(defaults, overrides)
+  end
+end
