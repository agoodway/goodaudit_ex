+                updated_at: %Schema{type: :string, format: :"date-time"}
+              },
+              required: [
+                :id,
+                :account_id,
+                :sequence_number,
+                :checksum,
+                :signature,
+                :verified_at,
+                :signing_key_id,
+                :inserted_at,
+                :updated_at
+              ]
+            }
+          }
+        ]
+      }
+    },
+    required: [:data]
