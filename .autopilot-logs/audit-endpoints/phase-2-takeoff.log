+      source_ip: "127.0.0.1",
+      user_agent: "ExUnit",
+      outcome: "success",
+      failure_reason: nil,
+      phi_accessed: false,
+      metadata: %{"source" => "checkpoint_controller_test"}
+    }
+
+    Map.merge(defaults, overrides)
+  end
+end
