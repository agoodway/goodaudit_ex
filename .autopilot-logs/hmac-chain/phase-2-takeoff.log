+      resource_id: "pt_1",
+      outcome: "success",
+      failure_reason: nil,
+      phi_accessed: true,
+      source_ip: "127.0.0.1",
+      user_agent: "Mozilla/5.0",
+      metadata: %{"zeta" => 2, "alpha" => 1}
+    }
+  end
