+defmodule GA.Repo.Migrations.AddHmacKeyToAccounts do
+  use Ecto.Migration
+
+  alias Ecto.Adapters.SQL
+
+  def up do
+    alter table(:accounts) do
+      add :hmac_key, :binary
+    end
+
+    flush()
+    backfill_hmac_keys()
+
+    alter table(:accounts) do
+      modify :hmac_key, :binary, null: false
+    end
+  end
+
